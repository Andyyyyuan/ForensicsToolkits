# Docker Compose project
COMPOSE_PROJECT_NAME=forensicstoolkits
TZ=Asia/Shanghai

# Aliyun ACR images
FRONTEND_IMAGE=crpi-b0crof0akjbozky4.cn-hangzhou.personal.cr.aliyuncs.com/enxiaohao/forensicstoolkits-frontend:latest
BACKEND_IMAGE=crpi-b0crof0akjbozky4.cn-hangzhou.personal.cr.aliyuncs.com/enxiaohao/forensicstoolkits-backend:latest

# Published ports
FRONTEND_PORT=8080
BACKEND_PORT=8000

# Host bind mounts, relative to the release/ directory
BACKEND_DATA_DIR=./data/backend/data
BACKEND_UPLOADS_DIR=./data/backend/uploads
BACKEND_LOGS_DIR=./data/backend/logs
BACKEND_REPORTS_DIR=./data/backend/reports

APP_ENV=production
CORS_ALLOW_ALL=false
CORS_ALLOW_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

APP_STORAGE_DIR=/app/storage
APP_DATA_DIR=/app/storage/data
APP_DB_PATH=/app/storage/data/app.db
APP_UPLOAD_DIR=/app/storage/uploads
APP_LOG_DIR=/app/storage/logs
APP_REPORT_DIR=/app/storage/reports
APP_MAX_UPLOAD_BYTES=104857600

# AI assistant, fill AI_API_KEY to enable
AI_API_BASE_URL=https://api.deepseek.com
AI_API_KEY=
AI_MODEL=deepseek-chat
AI_CHAT_MODEL=deepseek-chat
AI_REASONER_MODEL=deepseek-reasoner

# Optional runtime overrides
HASHCAT_BINARY_PATH=
HASHCAT_BUNDLE_DIR=/opt/hashcat
HASHCAT_WORDLISTS_DIR=/opt/hashcat
HASHCAT_RUNTIME_DIR=/app/storage/data/hashcat-runtime
CYBERCHEF_DIR=

TOOL_LOG_PARSER_ENABLED=true
TOOL_LOG_PARSER_UPLOAD_MAX_SIZE_BYTES=10485760
TOOL_LOG_PARSER_DISABLED_TITLE=日志分析暂不可用
TOOL_LOG_PARSER_DISABLED_MESSAGE=当前部署未启用日志分析模块，请在配置文件中打开该功能后重试。

TOOL_HASH_TOOL_ENABLED=true
TOOL_HASH_TOOL_MAX_SIZE_BYTES=1048576
TOOL_HASH_TOOL_UPLOAD_MAX_SIZE_BYTES=1048576
TOOL_HASH_TOOL_DISABLED_TITLE=文件哈希暂不可用
TOOL_HASH_TOOL_DISABLED_MESSAGE=当前部署未启用文件哈希模块，请联系管理员或调整部署配置。

TOOL_SQLITE2CSV_ENABLED=true
TOOL_SQLITE2CSV_UPLOAD_MAX_SIZE_BYTES=67108864
TOOL_SQLITE2CSV_DISABLED_TITLE=SQLite2CSV 暂不可用
TOOL_SQLITE2CSV_DISABLED_MESSAGE=当前部署未启用 SQLite 导出模块，请在配置中开启后重试。

TOOL_TIMESTAMP_PARSER_ENABLED=true
TOOL_TIMESTAMP_PARSER_DISABLED_TITLE=时间戳解析暂不可用
TOOL_TIMESTAMP_PARSER_DISABLED_MESSAGE=当前部署未启用时间戳解析模块，请在配置中开启后重试。

TOOL_HASHCAT_GUI_ENABLED=false
TOOL_HASHCAT_GUI_UPLOAD_MAX_SIZE_BYTES=5242880
TOOL_HASHCAT_GUI_DISABLED_TITLE=Hashcat 仅限本地使用
TOOL_HASHCAT_GUI_DISABLED_MESSAGE=当前镜像部署默认禁用 Hashcat 图形化能力，如需启用请确认主机具备可用 OpenCL 环境后再开启。

TOOL_ENCODING_CONVERTER_ENABLED=false
TOOL_ENCODING_CONVERTER_DISABLED_TITLE=编码转换暂不可用
TOOL_ENCODING_CONVERTER_DISABLED_MESSAGE=当前发布镜像未挂载 CyberChef 目录，如需启用请设置 CYBERCHEF_DIR 并挂载对应文件。
